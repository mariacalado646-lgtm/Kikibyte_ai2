@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";
@import "@fontsource-variable/geist";

/* @import './fonts.css'; */
@import './styles/theme.css';

@custom-variant dark (&:is(.dark *));

:root {
  --font-size: 16px;
  --background: #FAFAF9;
  --foreground: #1C1917;
  --card: #ffffff;
  --card-foreground: #1C1917;
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.145 0 0);
  --primary: #78350F;
  --primary-foreground: #FAFAF9;
  --secondary: #A8A29E;
  --secondary-foreground: #1C1917;
  --muted: #E7E5E4;
  --muted-foreground: #57534E;
  --accent: #A67C52;
  --accent-foreground: #FAFAF9;
  --destructive: #d4183d;
  --destructive-foreground: #ffffff;
  --border: rgba(120, 53, 15, 0.15);
  --input: transparent;
  --input-background: #f3f3f5;
  --switch-background: #cbced4;
  --font-weight-medium: 500;
  --font-weight-normal: 400;
  --ring: oklch(0.708 0 0);
  --chart-1: oklch(0.646 0.222 41.116);
  --chart-2: oklch(0.6 0.118 184.704);
  --chart-3: oklch(0.398 0.07 227.392);
  --chart-4: oklch(0.828 0.189 84.429);
  --chart-5: oklch(0.769 0.188 70.08);
  --radius: 0.625rem;
  --sidebar: oklch(0.985 0 0);
  --sidebar-foreground: oklch(0.145 0 0);
  --sidebar-primary: #78350F;
  --sidebar-primary-foreground: oklch(0.985 0 0);
  --sidebar-accent: oklch(0.97 0 0);
  --sidebar-accent-foreground: oklch(0.205 0 0);
  --sidebar-border: oklch(0.922 0 0);
  --sidebar-ring: oklch(0.708 0 0);
}

.dark {
  --background: oklch(0.145 0 0);
  --foreground: oklch(0.985 0 0);
  --card: oklch(0.145 0 0);
  --card-foreground: oklch(0.985 0 0);
  --popover: oklch(0.145 0 0);
  --popover-foreground: oklch(0.985 0 0);
  --primary: oklch(0.985 0 0);
  --primary-foreground: oklch(0.205 0 0);
  --secondary: oklch(0.269 0 0);
  --secondary-foreground: oklch(0.985 0 0);
  --muted: oklch(0.269 0 0);
  --muted-foreground: oklch(0.708 0 0);
  --accent: oklch(0.269 0 0);
  --accent-foreground: oklch(0.985 0 0);
  --destructive: oklch(0.396 0.141 25.723);
  --destructive-foreground: oklch(0.637 0.237 25.331);
  --border: oklch(0.269 0 0);
  --input: oklch(0.269 0 0);
  --ring: oklch(0.439 0 0);
  --font-weight-medium: 500;
  --font-weight-normal: 400;
  --chart-1: oklch(0.488 0.243 264.376);
  --chart-2: oklch(0.696 0.17 162.48);
  --chart-3: oklch(0.769 0.188 70.08);
  --chart-4: oklch(0.627 0.265 303.9);
  --chart-5: oklch(0.645 0.246 16.439);
  --sidebar: oklch(0.205 0 0);
  --sidebar-foreground: oklch(0.985 0 0);
  --sidebar-primary: oklch(0.488 0.243 264.376);
  --sidebar-primary-foreground: oklch(0.985 0 0);
  --sidebar-accent: oklch(0.269 0 0);
  --sidebar-accent-foreground: oklch(0.985 0 0);
  --sidebar-border: oklch(0.269 0 0);
  --sidebar-ring: oklch(0.439 0 0);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-input-background: var(--input-background);
  --color-switch-background: var(--switch-background);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  body {
    @apply bg-background text-foreground;
  }

  /**
  * Default typography styles for HTML elements (h1-h4, p, label, button, input).
  * These are in @layer base, so Tailwind utility classes (like text-sm, text-lg) automatically override them.
  */

  html {
    font-size: var(--font-size);
  }

  h1 {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  h2 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  h3 {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  h4 {
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  label {
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  button {
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
  }

  input {
    font-size: var(--text-base);
    font-weight: var(--font-weight-normal);
    line-height: 1.5;
  }
}


/* ── KikiByte Design Tokens ── */
:root {
  --kb-primary: #c2410c;
  --kb-primary-h: #9a3412;
  --kb-accent: #ea580c;
  --kb-muted: #f5f0eb;
  --kb-muted-fg: #78716c;
  --kb-border: #e7e5e4;
}

/* Navbar */
.kb-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(255, 255, 255, .95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--kb-border);
}

.kb-logo {
  cursor: pointer;
}

.kb-logo-text {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--kb-primary);
}

.kb-nav-link {
  background: none;
  border: none;
  color: #1c1917;
  font-size: .9375rem;
  padding: .25rem 0;
  transition: color .2s;
}

.kb-nav-link:hover {
  color: var(--kb-primary);
}

.kb-hamburger {
  background: none;
  border: none;
}

.kb-mobile-menu {
  background: #fff;
  border-top: 1px solid var(--kb-border);
}

/* Hero */
.kb-hero {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f0eb 0%, #fafaf9 50%, #fff7ed 100%);
  position: relative;
  overflow: hidden;
  padding-top: 80px;
}

.kb-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml;base64,");
  opacity: .5;
  pointer-events: none;
}

.kb-content {
  position: relative;
  z-index: 1;
}

.kb-h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.15;
  color: #1c1917;
}

.kb-lead {
  font-size: 1.125rem;
  color: var(--kb-muted-fg);
  max-width: 480px;
  line-height: 1.7;
}

.kb-mascot-wrap {
  position: relative;
  display: inline-block;
}

.kb-glow {
  position: absolute;
  inset: -10%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(194, 65, 12, .18) 0%, transparent 70%);
  animation: kb-pulse 2.5s ease-in-out infinite;
}

.kb-mascot-img {
  position: relative;
  width: 320px;
  height: 320px;
  object-fit: contain;
  filter: drop-shadow(0 20px 40px rgba(0, 0, 0, .15));
}

@keyframes kb-pulse {

  0%,
  100% {
    opacity: .6;
    transform: scale(1);
  }

  50% {
    opacity: 1;
    transform: scale(1.08);
  }
}

.kb-scroll-btn {
  background: none;
  border: none;
  color: var(--kb-muted-fg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .375rem;
  font-size: .8125rem;
  cursor: pointer;
  transition: color .2s;
  animation: kb-bounce 1.5s ease-in-out infinite;
}

.kb-scroll-btn:hover {
  color: var(--kb-primary);
}

@keyframes kb-bounce {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(8px);
  }
}

/* Buttons */
.btn-kb-primary {
  background: var(--kb-primary);
  color: #fff;
  border: none;
  padding: .75rem 2rem;
  border-radius: .5rem;
  font-weight: 500;
  font-size: .9375rem;
  transition: background .2s, transform .15s, box-shadow .2s;
  box-shadow: 0 4px 14px rgba(194, 65, 12, .25);
  display: inline-flex;
  align-items: center;
  gap: .5rem;
}

.btn-kb-primary:hover:not(:disabled) {
  background: var(--kb-primary-h);
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(194, 65, 12, .35);
  color: #fff;
}

.btn-kb-primary:disabled {
  opacity: .6;
  cursor: not-allowed;
}

.btn-kb-outline {
  background: transparent;
  color: var(--kb-primary);
  border: 2px solid var(--kb-primary);
  padding: .75rem 2rem;
  border-radius: .5rem;
  font-weight: 500;
  font-size: .9375rem;
  transition: background .2s, color .2s, transform .15s;
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  text-decoration: none;
}

.btn-kb-outline:hover {
  background: var(--kb-primary);
  color: #fff;
  transform: translateY(-1px);
}

.btn-kb-outline-sm {
  background: rgba(194, 65, 12, .08);
  color: var(--kb-primary);
  border: 1.5px solid var(--kb-primary);
  padding: .375rem 1rem;
  border-radius: .5rem;
  font-weight: 600;
  font-size: .8125rem;
  transition: background .2s;
  display: inline-flex;
  align-items: center;
  gap: .375rem;
}

.btn-kb-outline-sm:hover {
  background: rgba(194, 65, 12, .16);
}

.btn-kb-primary-sm {
  background: var(--kb-primary);
  color: #fff;
  border: none;
  padding: .375rem 1rem;
  border-radius: .5rem;
  font-size: .875rem;
  display: inline-flex;
  align-items: center;
  gap: .375rem;
}

/* Shared */
.kb-brand {
  color: var(--kb-primary);
}

.kb-icon {
  color: var(--kb-primary);
}

.kb-bg-muted {
  background: linear-gradient(135deg, var(--kb-muted) 0%, #fafaf9 100%);
}

.kb-section-title {
  font-size: clamp(1.5rem, 4vw, 2.25rem);
  font-weight: 800;
  color: #1c1917;
  margin-bottom: .75rem;
}

.kb-section-sub {
  font-size: 1.0625rem;
  color: var(--kb-muted-fg);
  max-width: 700px;
  margin: 0 auto;
}

.kb-card {
  background: linear-gradient(135deg, rgba(245, 240, 235, .5), rgba(255, 247, 237, .3));
  padding: 2rem;
  border-radius: 1rem;
  border: 1px solid var(--kb-border);
  transition: box-shadow .3s, transform .3s;
}

.kb-card:hover {
  box-shadow: 0 12px 40px rgba(0, 0, 0, .1);
  transform: translateY(-4px);
}

.kb-card-title {
  font-size: 1.125rem;
  font-weight: 600;
  color: #1c1917;
  margin-bottom: .75rem;
}

.kb-icon-box {
  background: rgba(194, 65, 12, .08);
  width: 56px;
  height: 56px;
  border-radius: .75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kb-icon-box-lg {
  background: rgba(194, 65, 12, .08);
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kb-stat-value {
  font-size: clamp(1.75rem, 4vw, 2.25rem);
  font-weight: 800;
  color: var(--kb-primary);
  margin-bottom: .25rem;
}

.kb-stat-label {
  font-size: .875rem;
  color: var(--kb-muted-fg);
}

/* Services */
.kb-service-card {
  background: #fff;
  padding: 1.5rem;
  border-radius: .75rem;
  border: 1px solid var(--kb-border);
  transition: box-shadow .3s, transform .3s;
}

.kb-service-card:hover {
  box-shadow: 0 8px 30px rgba(0, 0, 0, .08);
  transform: translateY(-4px);
}

.kb-service-icon-box {
  background: rgba(194, 65, 12, .08);
  width: 52px;
  height: 52px;
  border-radius: .625rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .3s;
}

.kb-service-card:hover .kb-service-icon-box {
  background: var(--kb-primary);
}

.kb-service-card:hover .kb-service-icon-box .kb-icon {
  color: #fff;
}

/* Compliance */
.kb-compliance-card {
  background: linear-gradient(135deg, rgba(194, 65, 12, .04), rgba(234, 88, 12, .08));
  padding: 2rem;
  border-radius: 1rem;
  border: 2px solid rgba(194, 65, 12, .15);
}

.kb-compliance-card-accent {
  background: linear-gradient(135deg, rgba(234, 88, 12, .08), rgba(194, 65, 12, .04));
  padding: 2rem;
  border-radius: 1rem;
  border: 2px solid rgba(234, 88, 12, .2);
}

.kb-icon-box-primary {
  background: var(--kb-primary);
  width: 64px;
  height: 64px;
  border-radius: .75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kb-icon-box-accent {
  background: var(--kb-accent);
  width: 64px;
  height: 64px;
  border-radius: .75rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kb-banner {
  background: linear-gradient(135deg, var(--kb-primary), var(--kb-accent));
}

.kb-banner-btn {
  background: #fff;
  color: var(--kb-primary);
  border: none;
  padding: .75rem 2rem;
  border-radius: .5rem;
  font-weight: 600;
  transition: background .2s;
}

.kb-banner-btn:hover {
  background: var(--kb-muted);
}

/* News */
.kb-news-card {
  background: #fff;
  border-radius: .75rem;
  border: 1px solid var(--kb-border);
  overflow: hidden;
  transition: box-shadow .3s, transform .3s;
}

.kb-news-card:hover {
  box-shadow: 0 12px 40px rgba(0, 0, 0, .1);
  transform: translateY(-6px);
}

.kb-news-img-wrap {
  position: relative;
  height: 192px;
  overflow: hidden;
}

.kb-news-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .5s;
}

.kb-news-card:hover .kb-news-img {
  transform: scale(1.1);
}

.kb-news-badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: var(--kb-primary);
  color: #fff;
  font-size: .75rem;
  padding: .2rem .75rem;
  border-radius: 999px;
}

.kb-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.kb-read-more {
  font-size: .875rem;
  color: var(--kb-primary);
  display: inline-flex;
  align-items: center;
  gap: .375rem;
  transition: gap .2s;
}

.kb-news-card:hover .kb-read-more {
  gap: .625rem;
}

/* Contact */
.kb-form-box {
  background: linear-gradient(135deg, rgba(245, 240, 235, .3), rgba(255, 247, 237, .05));
  border: 1px solid var(--kb-border);
}

.kb-input {
  border-color: var(--kb-border) !important;
  border-radius: .5rem !important;
}

.kb-input:focus {
  box-shadow: 0 0 0 3px rgba(194, 65, 12, .15) !important;
  border-color: var(--kb-primary) !important;
}

.kb-dropzone {
  border: 2px dashed var(--kb-border);
  border-radius: .5rem;
  padding: 2rem;
  text-align: center;
  cursor: pointer;
  transition: border-color .2s, background .2s;
}

.kb-dropzone:hover {
  border-color: rgba(194, 65, 12, .4);
  background: rgba(194, 65, 12, .03);
}

.kb-hours-box {
  background: linear-gradient(135deg, rgba(194, 65, 12, .04), rgba(234, 88, 12, .08));
  border: 1px solid rgba(194, 65, 12, .15);
}

.kb-hover-primary:hover {
  color: var(--kb-primary) !important;
}

/* Pages shared */
.kb-page-wrap {
  min-height: 100vh;
  padding-top: 72px;
  background: #fafaf9;
}

/* NewsPage hero */
.kb-news-hero {
  background: linear-gradient(135deg, #f5f0eb 0%, #fafaf9 100%);
}

.kb-search-wrap {
  position: relative;
  max-width: 420px;
}

.kb-search-icon {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--kb-muted-fg);
  pointer-events: none;
}

.kb-search-input {
  padding-left: 2.75rem !important;
  border-radius: .75rem !important;
  border-color: var(--kb-border) !important;
}

.kb-search-input:focus {
  box-shadow: 0 0 0 3px rgba(194, 65, 12, .15) !important;
  border-color: var(--kb-primary) !important;
}

/* Category buttons */
.kb-cat-btn {
  background: #fff;
  border: 1.5px solid var(--kb-border);
  color: var(--kb-muted-fg);
  padding: .375rem 1rem;
  border-radius: 999px;
  font-size: .8125rem;
  display: inline-flex;
  align-items: center;
  gap: .375rem;
  transition: border-color .2s, color .2s;
}

.kb-cat-btn:hover {
  border-color: var(--kb-primary);
  color: var(--kb-primary);
}

.kb-cat-btn-active {
  background: var(--kb-primary) !important;
  border-color: var(--kb-primary) !important;
  color: #fff !important;
}

/* Featured card */
.kb-featured-card {
  transition: box-shadow .3s;
}

.kb-featured-card:hover {
  box-shadow: 0 12px 40px rgba(0, 0, 0, .1);
}

.kb-featured-img-wrap {
  position: relative;
  min-height: 260px;
  overflow: hidden;
}

.kb-featured-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .5s;
}

.kb-featured-card:hover .kb-featured-img {
  transform: scale(1.05);
}

.kb-news-badge-dark {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(0, 0, 0, .6);
  color: #fff;
  font-size: .75rem;
  padding: .2rem .75rem;
  border-radius: 999px;
}

/* Clamp utilities */
.kb-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.kb-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Spinner */
.kb-spin {
  animation: kb-rotate 1s linear infinite;
}

@keyframes kb-rotate {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

/* Article page */
.kb-back-btn {
  background: none;
  border: none;
  transition: color .2s;
}

.kb-back-btn:hover {
  color: var(--kb-primary) !important;
}

.kb-article-img {
  max-height: 360px;
  object-fit: cover;
}

.kb-article-body {
  font-size: 1.0625rem;
  line-height: 1.8;
  color: #1c1917;
  white-space: pre-wrap;
}